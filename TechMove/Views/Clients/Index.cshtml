

@model IEnumerable<TechMove.Models.Client>

@{
    ViewData["Title"] = "Clients";
}

<h2>Clients</h2>
<a asp-action="Create" class="btn btn-primary mb-3">+ Add New Client</a>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>Name</th>
            <th>Contact</th>
            <th>Region</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var client in Model)
        {
            <tr>
                <td>@client.Name</td>
                <td>@client.ContactDetails</td>
                <td>@client.Region</td>
                <td>
                    <a asp-action="Details" asp-route-id="@client.Id" class="btn btn-sm btn-info">View</a>
                    <a asp-action="Edit" asp-route-id="@client.Id" class="btn btn-sm btn-warning">Edit</a>
                    <a asp-action="Delete" asp-route-id="@client.Id" class="btn btn-sm btn-danger">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>