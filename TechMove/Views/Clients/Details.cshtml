@model TechMove.Models.Client

@{
    ViewData["Title"] = "Client Details";
}

<h2>@Model.Name</h2>
<p><strong>Contact:</strong> @Model.ContactDetails</p>
<p><strong>Region:</strong> @Model.Region</p>

<hr />
<h4>Contracts</h4>

@if (Model.Contracts != null && Model.Contracts.Any())
{
    <table class="table table-sm">
        <thead>
            <tr>
                <th>Status</th>
                <th>Service Level</th>
                <th>Start</th>
                <th>End</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var c in Model.Contracts)
            {
                <tr>
                    <td>@c.Status</td>
                    <td>@c.ServiceLevel</td>
                    <td>@c.StartDate.ToShortDateString()</td>
                    <td>@c.EndDate.ToShortDateString()</td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <p>No contracts yet for this client.</p>
}

<a asp-action="Index" class="btn btn-secondary mt-2">Back</a>