@model TechMove.Models.Contract

@{
    ViewData["Title"] = "Edit Contract";
}

<h2>Edit Contract</h2>

@if (!ViewData.ModelState.IsValid)
{
    <div class="alert alert-danger">
        @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
        {
            <p>@error.ErrorMessage</p>
        }
    </div>
}

<form asp-action="Edit" method="post" enctype="multipart/form-data">
    <input type="hidden" asp-for="Id" />
    <div class="mb-3">
        <label asp-for="ClientId" class="form-label">Client</label>
        <select asp-for="ClientId" asp-items="ViewBag.Clients" class="form-select"></select>
        <span asp-validation-for="ClientId" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="Status" class="form-label"></label>
        <select asp-for="Status" asp-items="ViewBag.StatusOptions" class="form-select"></select>
        <span asp-validation-for="Status" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="ServiceLevel" class="form-label"></label>
        <select asp-for="ServiceLevel" asp-items="ViewBag.ServiceLevels" class="form-select"></select>
        <span asp-validation-for="ServiceLevel" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="StartDate" class="form-label"></label>
        <input asp-for="StartDate" class="form-control" type="date" />
        <span asp-validation-for="StartDate" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="EndDate" class="form-label"></label>
        <input asp-for="EndDate" class="form-control" type="date" />
        <span asp-validation-for="EndDate" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label class="form-label">Signed Agreement (PDF only)</label>
        @if (!string.IsNullOrEmpty(Model.SignedAgreementPath))
        {
            <p class="text-success">
                ✅ File already uploaded: @Model.SignedAgreementPath
            </p>
            <small class="text-muted">Upload a new file below to replace it</small>
        }
        <input type="file" name="pdfFile" class="form-control mt-2" accept=".pdf" />
    </div>
    <button type="submit" class="btn btn-success">Update</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>