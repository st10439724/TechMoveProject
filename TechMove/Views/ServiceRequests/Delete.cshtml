@model TechMove.Models.ServiceRequest

@{
    ViewData["Title"] = "Delete Service Request";
}

<h2>Delete Service Request</h2>
<p>Are you sure you want to delete this service request?</p>
<p><strong>Description:</strong> @Model.Description</p>
<p><strong>Cost (USD):</strong> $@Model.CostUSD.ToString("N2")</p>
<p><strong>Status:</strong> @Model.Status</p>

<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Yes, Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>