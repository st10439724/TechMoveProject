@model TechMove.Models.ServiceRequest

@{
    ViewData["Title"] = "New Service Request";
    var exchangeRate = ViewBag.ExchangeRate ?? 18.50;
}

<h2>Raise Service Request</h2>

@* show the live rate so the user knows what rate is being used *@
<div class="alert alert-info">
    <strong>Live Exchange Rate:</strong> 1 USD = R @exchangeRate ZAR
</div>

@if (!ViewData.ModelState.IsValid)
{
    <div class="alert alert-danger">
        @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
        {
            <p>@error.ErrorMessage</p>
        }
    </div>
}

<form asp-action="Create" method="post">
    <div class="mb-3">
        <label asp-for="ContractId" class="form-label">Contract</label>
        <select asp-for="ContractId" asp-items="ViewBag.Contracts" class="form-select">
            <option value="">-- Select Active Contract --</option>
        </select>
        <span asp-validation-for="ContractId" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="Description" class="form-label"></label>
        <textarea asp-for="Description" class="form-control" rows="3"></textarea>
        <span asp-validation-for="Description" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="CostUSD" class="form-label">Cost (USD)</label>
        <input asp-for="CostUSD" class="form-control"
               type="number" step="0.01" id="costUSD" />
        <span asp-validation-for="CostUSD" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label class="form-label">Cost (ZAR) - Preview</label>
        <input type="text" id="costZARDisplay" class="form-control" readonly />
    </div>
    <div class="mb-3">
        <label asp-for="Status" class="form-label"></label>
        <select asp-for="Status" asp-items="ViewBag.StatusOptions" class="form-select">
            <option value="">-- Select Status --</option>
        </select>
        <span asp-validation-for="Status" class="text-danger"></span>
    </div>
    <button type="submit" class="btn btn-success">Submit Request</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>

<script>
    // use the live rate passed from the controller for the preview
    var liveRate = @exchangeRate;

    document.getElementById('costUSD').addEventListener('input', function () {
        var usd = parseFloat(this.value) || 0;
        var zar = (usd * liveRate).toFixed(2);
        document.getElementById('costZARDisplay').value = 'R ' + zar;
    });
</script>